    // Savings calculator
    document.getElementById('calcSavings').addEventListener('click', ()=>{
      const monthly = parseFloat(document.getElementById('sMonthly').value) || 0;
      const annualReturn = (parseFloat(document.getElementById('sReturn').value) || 0)/100;
      const years = parseFloat(document.getElementById('sYears').value) || 0;
      const r = annualReturn/12;
      const n = years*12;
      let fv = 0;
      if(r === 0) fv = monthly * n;
      else fv = monthly * ( (Math.pow(1+r, n) - 1) / r ) * (1 + r);
      const invested = monthly * n;
      document.getElementById('projCorpus').textContent = '₹' + fv.toFixed(0);
      document.getElementById('totalInvested').textContent = '₹' + invested.toFixed(0);
    });

