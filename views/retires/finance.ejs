
<% layout("./layout/boiler.ejs") %>
  <style>
    :root{
      --bg: #f6f8fb;
      --card: #ffffff;
      --muted: #6b7280;
      --accent: #19376d;
      --primary: #335eea;
      --primary-600: #2749c8;
      --glass: rgba(255,255,255,0.65);
      --glass-2: rgba(19,55,109,0.06);
      --max-width: 1180px;
      --radius: 14px;
      --shadow-sm: 0 6px 20px rgba(20,20,50,0.06);
      --shadow-lg: 0 10px 40px rgba(20,20,50,0.09);
    }

    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;
      font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
      background: linear-gradient(180deg, #f7f9fe, var(--bg));
      color:#111827;
      -webkit-font-smoothing:antialiased;
      -moz-osx-font-smoothing:grayscale;
      line-height:1.45;
    }

    /* Header */
    header{
      position:sticky;
      top:0;
      z-index:1200;
      background:rgba(255,255,255,0.9);
      backdrop-filter: blur(6px);
      box-shadow: 0 1px 0 rgba(20,20,50,0.04);
      border-bottom: 1px solid rgba(16,24,40,0.03);
    }
    .header-inner{
      max-width:var(--max-width);
      margin:0 auto;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding:12px 20px;
    }
    .brand{
      display:flex;align-items:center;gap:12px;font-weight:700;color:var(--accent)
    }
    .brand img{width:40px;height:40px;border-radius:8px;object-fit:cover;filter:grayscale(100%) contrast(0.95) brightness(0.95)}
    nav.desktop{display:flex;gap:18px;align-items:center}
    nav.desktop a{color:#334155;text-decoration:none;font-weight:600;padding:8px 12px;border-radius:10px}
    nav.desktop a.active{background:linear-gradient(90deg,var(--primary),var(--primary-600)); color:white; box-shadow:var(--shadow-sm)}
    .hamburger{display:none;cursor:pointer;border:none;background:transparent;padding:8px;border-radius:8px}
    .hamburger svg{width:24px;height:24px;color:var(--accent)}

    /* Container */
    .container{max-width:var(--max-width);margin:0 auto;padding:20px;width:100%}

    /* Hero */
    .hero{
      margin-top:16px;
      border-radius:18px;
      overflow:hidden;
      position:relative;
      min-height:300px;
      display:flex;
      align-items:center;
      justify-content:center;
    }
   .hero-bg{
  position: absolute;
  inset: 0;
  background-image: url('financwe.jpg');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  transform: scale(1.02);
  filter: contrast(0.9) saturate(0.92);
}

    .hero-overlay{ position:absolute; inset:0; background: linear-gradient(180deg, rgba(9,30,66,0.50), rgba(9,30,66,0.28));}
    .hero-content{
      position:relative; z-index:2; color:white; text-align:center; padding:36px 22px; max-width:980px;
      display:flex;flex-direction:column;gap:12px; align-items:center;
     
    }
    .hero h1{font-size:28px;margin:0;font-weight:800;letter-spacing:0.2px}
    .hero p{margin:0;opacity:0.95;max-width:820px}
    .hero-ctas{display:flex;gap:12px;margin-top:10px;flex-wrap:wrap}
    .btn{
      display:inline-flex;align-items:center;gap:10px;padding:10px 16px;border-radius:999px;border:none;cursor:pointer;font-weight:700;
      box-shadow:none;transition:transform .15s ease, box-shadow .15s ease;
    }
    .btn-primary{background:var(--primary);color:white}
    .btn-primary:hover{transform:translateY(-3px);box-shadow:var(--shadow-sm)}
    .btn-ghost{background:transparent;color:white;border:1px solid rgba(255,255,255,0.18)}
    .hero-badge{
      margin-top:8px;background:rgba(255,255,255,0.06);padding:6px 10px;border-radius:999px;font-size:13px;color:#e6eefc;border:1px solid rgba(255,255,255,0.04)
    }

    /* Tools & Cards */
    .section-title{display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--accent);margin-top:22px}
    .cards{
      margin-top:18px;
      display:grid;
      grid-template-columns: repeat(4, 1fr);
      gap:18px;
    }
    .card{
      background:linear-gradient(180deg,var(--card),#fbfdff);
      border-radius:14px;padding:18px;box-shadow:var(--shadow-lg);border:1px solid var(--glass-2);
      transition:transform .15s ease, box-shadow .15s ease;
    }
    .card:hover{transform:translateY(-6px);box-shadow:0 20px 50px rgba(15,23,42,0.08)}
    .card h3{margin:0;color:var(--accent);font-size:16px}
    .card p{margin:8px 0 0;color:var(--muted);font-size:14px;line-height:1.35}

    /* Budget Tracker */
    .budget{
      margin-top:22px;background:transparent;padding:6px;
    }
    .tx-form{
      display:grid;grid-template-columns: 1fr 140px 130px 150px auto;gap:10px;
      align-items:center;
      margin-top:8px;
    }
    .tx-form input,.tx-form select{padding:12px;border-radius:10px;border:1px solid #e6e9ef;background:white;font-size:14px}
    .tx-form .btn{padding:10px 14px;border-radius:10px}
    .summary{
      display:grid;grid-template-columns: repeat(3,1fr);gap:12px;margin-top:14px;
    }
    .summary .stat{
      background:var(--card);padding:14px;border-radius:10px;box-shadow:var(--shadow-sm);text-align:center;border:1px solid var(--glass-2)
    }
    .stat .label{font-size:13px;color:var(--muted)}
    .stat .value{margin-top:6px;font-weight:800;font-size:18px;color:#0f172a}

    .tx-list{margin-top:14px;display:flex;flex-direction:column;gap:10px;padding:0;list-style:none}
    .tx-item{display:flex;align-items:center;justify-content:space-between;padding:12px;border-radius:10px;background:var(--card);border:1px solid var(--glass-2);box-shadow:var(--shadow-sm)}
    .tx-left{display:flex;align-items:center;gap:12px}
    .tx-cat{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#eaf2ff,#f6f9ff);font-weight:700;color:var(--primary)}
    .tx-meta{color:var(--muted);font-size:13px}
    .tx-right{text-align:right}
    .delete-btn{background:transparent;border:none;color:var(--muted);cursor:pointer;padding:6px;border-radius:8px}

    /* Savings & Receipts */
    .two-col{display:grid;grid-template-columns: 1fr 1fr;gap:18px;margin-top:18px}
    .panel{background:var(--card);padding:16px;border-radius:12px;border:1px solid var(--glass-2);box-shadow:var(--shadow-sm)}
    .panel h4{margin:0 0 8px;color:var(--accent)}
    .panel label{font-size:13px;color:var(--muted);display:block;margin-top:8px}
    .panel input{width:100%;padding:10px;border-radius:8px;border:1px solid #e6e9ef;margin-top:6px}

    .upload-area{display:flex;gap:12px;align-items:center;flex-wrap:wrap}
    .upload-btn{display:inline-flex;align-items:center;gap:8px;padding:10px 12px;border-radius:10px;border:1px dashed #dbe7ff;background:linear-gradient(180deg,#fff,#fbfdff);cursor:pointer}
    .preview-grid{display:flex;gap:10px;flex-wrap:wrap;margin-top:12px}

    .chart-card{margin-top:16px;padding:12px;border-radius:12px;background:var(--card);border:1px solid var(--glass-2);box-shadow:var(--shadow-sm)}
    .chart-responsive{position:relative;width:100%;min-height:200px}

    /* footer{margin-top:36px;text-align:center;color:var(--muted);padding:24px 6px} */

    /* Responsive Breakpoints */
    @media (max-width: 1000px){
      .cards{grid-template-columns: repeat(2, 1fr)}
      .tx-form{grid-template-columns: 1fr 120px 110px 130px auto}
      .two-col{grid-template-columns: 1fr}
    }
    @media (max-width: 720px){
      .header-inner{padding:10px 14px}
      nav.desktop{display:none}
      .hamburger{display:block}
      .hero{min-height:220px;border-radius:12px}
      .hero h1{font-size:20px}
      .hero p{font-size:14px}
      .cards{grid-template-columns:1fr}
      .tx-form{grid-template-columns:1fr;gap:10px}
      .tx-form input,.tx-form select{width:100%}
      .summary{grid-template-columns:1fr}
      .two-col{grid-template-columns:1fr}
      .brand img{width:34px;height:34px}
    }
  </style>
</head>

  <main class="container" id="main">
    <!-- HERO -->
    <section class="hero" aria-labelledby="heroTitle">
      <div class="hero-bg" role="img" aria-hidden="true"></div>
      <div class="hero-overlay" aria-hidden="true"></div>

      <div class="hero-content" id="heroTitle">
        <div class="hero-badge">Finance • Tools & Planning</div>
        <h1>Your Financial Well-being</h1>
        <p>Smart tools for budgeting, tracking expenses, planning savings, and storing receipts — made simple and accessible.</p>
        <div class="hero-ctas">
          <!-- <button class="btn btn-primary" id="openBudgetBtn" >Open Budget Tracker</button> -->
          <a href="#budgetTracker" class="btn btn-primary"> Open Budget Tracker </a>
          <button class="btn btn-ghost" onclick="document.getElementById('sMonthly').focus()">Savings Planner</button>
        </div>
      </div>
    </section>

    <!-- Tools -->
    <div class="section-title">Finance Tools</div>
    <div class="cards" role="list" aria-label="Finance tools">
      <div class="card cardh" role="listitem">
        <h3>Budget Tracker</h3>
        <p>Quickly log incomes and expenses, categorize, and track monthly balance.</p>
      </div>
      <div class="card cardh" role="listitem">
        <h3>Investment Planner</h3>
        <p>Estimate future corpus for regular contributions or one-time investments.</p>
      </div>
      <div class="card cardh" role="listitem">
        <h3>Expense Insights</h3>
        <p>Visual breakdowns by category to help you spot saving opportunities.</p>
      </div>
      <div class="card cardh" role="listitem">
        <h3>Receipts & Docs</h3>
        <p>Upload receipts and statements — preview locally or hook to a backend later.</p>
      </div>
    </div>

    <!-- Budget Tracker -->
    <section id="budgetTracker" class="budget" aria-labelledby="budgetTitle">
      <h2 id="budgetTitle" style="margin:8px 0 0;font-size:20px;color:var(--accent);">Budget Tracker</h2>

      <form class="tx-form" id="txForm" aria-label="Add transaction" action="/finance/budget" method="post">
        <input id="txDesc" type="text" name="desc" placeholder="Description" aria-label="Description" required />
        <select id="txType" aria-label="Type" name="type">
          <option value="income">Income</option>
          <option value="expense">Expense</option>
        </select>
        <input id="txAmount" type="number" name="amount" placeholder="Amount (₹)" min="0" step="0.01" aria-label="Amount" required />
        <select id="txCat" aria-label="Category" name="forWhich">
          <option>Income</option>
          <option>Groceries</option>
          <option>Health</option>
          <option>Transport</option>
          <option>Bills</option>
          <option>Other</option>
        </select>
        <div style="display:flex;gap:8px;justify-content:flex-end">
          <button class="btn btn-primary"  type="submit">Add</button>
          <a href="#"   onclick="return clearAllConfirm()" class="btn btn-outline-danger" style="border:1px solid red;border-radius:10px;text-decoration: none;">Clear</a>
        </div>
      </form>
<form id="clearAllForm"
      action="/finance/budget/?_method=DELETE"
      method="POST"
      style="display:none;">
</form>

<%
  let totalIncome = 0;
  let totalExpense = 0;

  if (txs && txs.length > 0) {
    txs.forEach(t => {
      if (t.type === "income") totalIncome += t.amount;
      else if (t.type === "expense") totalExpense += t.amount;
    });
  }

  let netBalance = totalIncome - totalExpense;
%>


      <div class="summary" role="status" aria-live="polite">
        <div class="stat" style="text-align:center">
          <div class="label">Total Income</div>
          <div class="value" id="totalIncome">₹<%= totalIncome.toFixed(2) %></div>
        </div>
        <div class="stat" style="text-align:center">
          <div class="label">Total Expense</div>
          <div class="value" id="totalExpense">₹<%= totalExpense.toFixed(2) %></div>
        </div>
        <div class="stat" style="text-align:center">
          <div class="label">Net Balance</div>
          <div class="value" id="netBalance">₹<%= netBalance.toFixed(2) %></div>
        </div>
      </div>

      <!-- <ul id="txList" class="tx-list" aria-live="polite" aria-label="Transaction list"></ul> -->


    <ul id="txList" class="tx-list" aria-live="polite" aria-label="Transaction list">
  <% if (txs && txs.length) { %>

    <% txs.forEach(t => { %>
      <li class="tx-item">
        <div class="tx-left">
          <div class="tx-cat" aria-hidden="true"><%= t.forWhich[0] %></div>
          <div>
            <div style="font-weight:700"><%= t.desc %></div>
            <div class="tx-meta"><%= t.forWhich %> • <%= t.type %></div>
          </div>
        </div>

        <div class="tx-right">
          <div style="font-weight:700">
            <% if (t.type === 'income') { %>
              ₹<%= t.amount.toFixed(2) %>
            <% } else { %>
              -₹<%= t.amount.toFixed(2) %>
            <% } %>
          </div>

          <form action="/finance/budget/<%= t._id %>/?_method=DELETE" method="POST" style="display:inline">
            <button class="delete-btn" aria-label="Delete transaction" type="submit">Delete</button>
          </form>
        </div>
      </li>
    <% }); %>

  <% } else { %>
    <li style="text-align:center;color:#94a3b8;padding:12px">No transactions yet</li>
  <% } %>
</ul>



      <div class="chart-card">
        <div style="display:flex;align-items:center;justify-content:space-between">
          <div style="font-weight:700;color:var(--accent)">Expense by Category  </div>
          <div style="font-size:13px;color:var(--muted)">Hover or tap a slice for details</div>
        </div>
        <div class="chart-responsive" style="margin-top:12px">
          <canvas id="expenseChart"></canvas>
        </div>
      </div>
    </section>
<br>
    <!-- Savings & Receipts -->
    <div class="w-100" id="sav" style="align-items:start">
      <div class="panel" aria-labelledby="savingsTitle">
        <h4 id="savingsTitle">Savings Planner</h4>
        <label for="sMonthly">Monthly Contribution (₹)</label>
        <input id="sMonthly" type="number" value="5000" inputmode="numeric" />

        <label for="sReturn">Expected Annual Return (%)</label>
        <input id="sReturn" type="number" value="8" />

        <label for="sYears">Years</label>
        <input id="sYears" type="number" value="5" />

        <div style="display:flex;gap:10px;margin-top:12px;align-items:center">
          <button class="btn btn-primary" id="calcSavings">Calculate</button>
          <div style="font-size:13px;color:var(--muted)">Assumes monthly compounding and start-of-month contributions.</div>
        </div>

        <div style="margin-top:12px">
          <div style="font-weight:700">Total Invested: <span id="totalInvested">₹0</span></div>
          <div style="font-weight:700;margin-top:6px">Projected Corpus: <span id="projCorpus">₹0</span></div>
        </div>
      </div>

      <!-- <div class="panel" aria-labelledby="receiptsTitle">
        <h4 id="receiptsTitle">Receipts & Documents</h4>
        <div class="upload-area">
          <label class="upload-btn" for="fileInp" role="button" tabindex="0">Choose files</label>
          <input id="fileInp" type="file" accept="image/*,application/pdf" multiple style="display:none" />
          <div style="flex:1;color:var(--muted);font-size:13px">Select images or PDFs. Previews are local (client-only).</div>
        </div>
        <div class="preview-grid" id="filePreview" aria-live="polite"></div>
      </div> -->
    </div>

  </main>

  <!-- Chart.js CDN -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<%
  let chartLabels = [];
  let chartValues = [];

  if (txs && txs.length > 0) {
    const catSums = {};

    txs.forEach(t => {
      if (t.type === "expense") {
        catSums[t.forWhich] = (catSums[t.forWhich] || 0) + t.amount;
      }
    });

    chartLabels = Object.keys(catSums);
    chartValues = chartLabels.map(l => catSums[l]);
  }
