// Read backend values
const labels = JSON.parse(`<%- JSON.stringify(chartLabels || []) %>`);
const values = JSON.parse(`<%- JSON.stringify(chartValues || []) %>`);


function initChart(labels = [], values = []) {
  if (expenseChart) expenseChart.destroy();

  const hasData = labels && labels.length > 0;

  expenseChart = new Chart(ctx, {
    type: "doughnut",
    data: {
      labels: hasData ? labels : ["No Data"],
      datasets: [{
        data: hasData ? values : [1],
        backgroundColor: hasData
          ? ['#3b82f6','#60a5fa','#7dd3fc','#34d399','#f59e0b','#f97316','#ef4444','#a78bfa']
          : ['#e2e8f0'],
        borderWidth: 0
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: hasData },
        tooltip: { enabled: hasData }
      }
    }
  });

  const card = document.querySelector(".chart-card");
  if (card) {
    let msg = card.querySelector(".no-data-msg");
    if (!hasData || hasData === 0 ) {
      if (!msg) {
        msg = document.createElement("div");
        msg.className = "no-data-msg";
        msg.style.cssText =
          "position:absolute;left:20px;right:20px;top:60px;text-align:center;color:#94a3b8;font-weight:600";
        msg.textContent =
          "No expense data yet — add an expense to see category breakdown.";
        card.appendChild(msg);
      }
    } else {
      if (msg) msg.remove();
    }
  }
}



// Show chart
initChart(labels, values);


function clearAllConfirm() {
  if (confirm("Clear all transactions?")) {
    document.getElementById("clearAllForm").submit();
  }
  return false;
}


