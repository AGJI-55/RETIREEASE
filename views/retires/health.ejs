    const height = parseFloat(document.getElementById('height').value);

    if(!weight || !height){
      setTextIfExists('bmiResult', 'Enter valid weight & height');
      return;
    }

    const bmi = weight / ((height/100) ** 2);
    let status = '';

    if(bmi < 18.5) status = 'Underweight';
