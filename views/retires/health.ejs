      function openRecord(id){
        try {
          const rows = loadFromStorage(STORAGE_KEYS.records); const r = rows.find(x=>x.id===id); if(!r) return alert('Record not found');
          const modal = document.getElementById('recordModal');
          if(!modal){
            // fallback simple viewer
            const fallback = document.createElement('div'); fallback.className='fixed inset-0 d-flex align-items-center justify-content-center';
            fallback.style.position='fixed'; fallback.style.left=0; fallback.style.top=0; fallback.style.right=0; fallback.style.bottom=0;
            fallback.style.background = 'rgba(0,0,0,0.5)';
            fallback.style.zIndex = 9999;
            fallback.innerHTML = `<div class="bg-white rounded p-3" style="max-width:900px;width:100%"><div class="d-flex justify-content-between align-items-center"><h5>${escapeHtml(r.title)}</h5><button class="btn btn-outline-secondary btn-sm">Close</button></div><div id="re_fallback_body" class="mt-3"></div></div>`;
            document.body.appendChild(fallback);
            fallback.querySelector('button').addEventListener('click', ()=> fallback.remove());
            const body = document.getElementById('re_fallback_body');
            populateRecordBody(body, r);
            return;
          }
          // use provided modal markup (if user has it)
          const titleEl = modal.querySelector('#modalTitle'); const bodyEl = modal.querySelector('#modalBody');
          if(titleEl) titleEl.textContent = r.title;
          if(bodyEl){ bodyEl.innerHTML=''; populateRecordBody(bodyEl, r); }
          // Show modal using Bootstrap if available, else fallback to simple show
          if(window.bootstrap && bootstrap.Modal){
            try {
              let inst = bootstrap.Modal.getInstance(modal);
              if(!inst) inst = new bootstrap.Modal(modal, {});
              inst.show();
            } catch(err){
              modal.classList.add('show'); modal.style.display = 'block';
            }
          } else {
            modal.classList.add('show'); modal.style.display = 'block';
          }
        } catch(e){ console.error('[re] openRecord', e); }
      }
      function populateRecordBody(container, r){
        try {
          if(r.type && r.type.startsWith('image')){ const img = document.createElement('img'); img.src = r.url; img.className='img-fluid file-preview'; container.appendChild(img); }
          else if(r.type === 'application/pdf' || (r.url && r.url.toLowerCase().endsWith('.pdf'))){ const iframe = document.createElement('iframe'); iframe.src = r.url; iframe.style.width='100%'; iframe.style.height='600px'; container.appendChild(iframe); }
          else if(r.type && (r.type.startsWith('text') || r.type==='text/plain')){ fetch(r.url).then(res=>res.text()).then(t=> { const pre = document.createElement('pre'); pre.className='small'; pre.textContent = t; container.appendChild(pre); }).catch(()=>{ const p = document.createElement('div'); p.textContent='Unable to load text file.'; container.appendChild(p); }); }
          else { const a = document.createElement('a'); a.href = r.url; a.textContent = 'Open file'; a.target = '_blank'; a.className='link-primary'; container.appendChild(a); }
        } catch(e){ console.error('[re] populateRecordBody', e); }
      }

      // ---------- Exercise modal + timer ----------
      let exercise = { timer: null, total: 0, remaining: 0, running: false, bsInstance: null };
      function fmtTime(sec){ const m = Math.floor(sec/60).toString().padStart(2,'0'); const s = Math.floor(sec%60).toString().padStart(2,'0'); return `${m}:${s}`; }

      function openExercise(id) {
        try {
          const title = id === 'gentle-cardio' ? 'Gentle Cardio — Low-impact' : 'Exercise';
          const titleEl = document.getElementById('exerciseTitle');
          if(titleEl) titleEl.innerText = title;

          // set image (use images/ path consistent with HTML)
          const imgEl = document.getElementById('exerciseImage');
          if(imgEl) imgEl.src = 'images/excercise.png';

          // default duration is whatever select has
          const durSel = document.getElementById('exerciseDuration');
          const dur = parseInt(durSel && durSel.value, 10) || 120;
          exercise.total = dur;
          exercise.remaining = dur;
          updateExerciseUI();

          const modal = document.getElementById('exerciseModal');
          if(!modal) return;
          // show modal using bootstrap if available, else fallback
          if(window.bootstrap && bootstrap.Modal){
            try {
              if(!exercise.bsInstance) exercise.bsInstance = new bootstrap.Modal(modal);
              exercise.bsInstance.show();
            } catch(err){
              modal.classList.add('show'); modal.style.display = 'block';
            }
          } else {
            modal.classList.add('show'); modal.style.display = 'block';
          }
        } catch(e){ console.error('[re] openExercise', e); }
      }

      window.openExercise = openExercise;

      function closeExercise(){ try { stopExercise(); const modalEl = document.getElementById('exerciseModal'); if(modalEl){ if(exercise.bsInstance && exercise.bsInstance.hide) try{ exercise.bsInstance.hide(); }catch(_){} modalEl.classList.remove('show'); modalEl.style.display = 'none'; } } catch(e){ console.error('[re] closeExercise', e); } }

      function startExercise(){ if(exercise.running) return; exercise.running = true; exercise.timer = setInterval(()=>{ try { if(exercise.remaining<=0){ stopExercise(); alert('Nice! Session complete 🎉'); return; } exercise.remaining -= 1; updateExerciseUI(); } catch(e){ console.error('[re] exercise tick', e); } },1000); }
      function pauseExercise(){ if(!exercise.running) return; exercise.running=false; clearInterval(exercise.timer); exercise.timer=null; }
      function stopExercise(){ clearInterval(exercise.timer); exercise.timer=null; exercise.running=false; exercise.remaining = exercise.total || 0; updateExerciseUI(); }
      function updateExerciseUI(){ setTextIfExists('exerciseTimer', fmtTime(exercise.remaining)); const prog = document.getElementById('exerciseProgress'); if(prog) prog.style.width = (exercise.total ? ((exercise.total - exercise.remaining)/exercise.total)*100 : 0) + '%'; }

