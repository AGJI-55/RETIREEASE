// Render booking list
function renderBookings() {
  const list = document.getElementById('appointmentsList');
  if(!list) return;

  const bookings = loadFromStorage(STORAGE_KEYS.bookings);

  list.innerHTML = "";

  if(bookings.length === 0){
    list.innerHTML = `<div class="text-muted small">No bookings yet.</div>`;
    return;
  }

  bookings.sort((a,b) => new Date(a.datetime) - new Date(b.datetime));

  bookings.forEach(item => {
    const li = document.createElement("li");
    li.className = "d-flex justify-content-between align-items-center p-2 border rounded mb-2 bg-white";

    li.innerHTML = `
      <div>
        <div class="fw-semibold">${escapeHtml(item.name)} — ${escapeHtml(item.type)}</div>
        <div class="small text-muted">${fmtDateTime(item.datetime)}</div>
      </div>
    `;

    const cancelBtn = document.createElement("button");
    cancelBtn.className = "btn btn-outline-secondary btn-sm";
    cancelBtn.innerText = "Cancel";
    cancelBtn.onclick = () => {
      removeBooking(item.id);
    };

    li.appendChild(cancelBtn);
    list.appendChild(li);
  });
}


// Delete booking
function removeBooking(id){
  let bookings = loadFromStorage(STORAGE_KEYS.bookings);
  bookings = bookings.filter(b => b.id !== id);
  saveToStorage(STORAGE_KEYS.bookings, bookings);
  renderBookings();
}


