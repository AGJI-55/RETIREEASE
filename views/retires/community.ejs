const blogsBtn = document.getElementById("showBlogsBtn");
const postsBtn = document.getElementById("showPostsBtn");

const blogsSection = document.getElementById("blogsSection");
const postsSection = document.getElementById("postsSection");

// SHOW BLOGS
blogsBtn.addEventListener("click", () => {
  blogsSection.classList.remove("d-none");
  postsSection.classList.add("d-none");

  blogsBtn.classList.add("active", "btn-primary");
  postsBtn.classList.remove("active", "btn-primary");
  postsBtn.classList.add("btn-outline-primary");
});

// SHOW POSTS
postsBtn.addEventListener("click", () => {
  postsSection.classList.remove("d-none");
  blogsSection.classList.add("d-none");

  postsBtn.classList.add("active", "btn-primary");
  blogsBtn.classList.remove("active", "btn-primary");
  blogsBtn.classList.add("btn-outline-primary");
});


    const openCreateGroup = document.getElementById('openCreateGroup');
    const createGroupModal = document.getElementById('createGroupModal');
    const closeCreateGroup = document.getElementById('closeCreateGroup');
 const newPostBtn = document.getElementById('newPostBtn');
    // const openNewPost = document.getElementById('openNewPost');
    const newPostModal = document.getElementById('newPostModal');
    const closeModal = document.getElementById('closeModal');


    
  if (openCreateGroup && createGroupModal) {
    openCreateGroup.addEventListener('click', () => {
      createGroupModal.classList.remove('hidden');
    });

    closeCreateGroup?.addEventListener('click', () => {
      createGroupModal.classList.add('hidden');
    });
  }
    [newPostBtn].forEach(btn => {
    if (btn && newPostModal) {
      btn.addEventListener('click', () => {
        newPostModal.classList.remove('hidden');
      });
    }
  });

  if (closeModal && newPostModal) {
    closeModal.addEventListener('click', () => {
      newPostModal.classList.add('hidden');
    });
  }

  // Escape key se close
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      createGroupModal?.classList.add('hidden');
      newPostModal?.classList.add('hidden');
    }
  });

